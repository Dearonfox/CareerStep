VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

MYSQL_DATABASE=careerstep
MYSQL_USER=careerstep
MYSQL_PASSWORD=careerstep_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql+pymysql://careerstep:careerstep_password@mysql:3306/careerstep

REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-main-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

AI_SERVICE_URL=http://ai-backend:8001/api/v1
INTERNAL_SERVICE_KEY=change-me-internal-service-key

OPENAI_API_KEY=sk-change-me
OPENAI_MODEL=gpt-4o-mini
AI_LOG_DB_PATH=/data/ai_logs.sqlite3

# MongoDB Atlas (ai-backend의 채용공고/대외활동 조회, crawler-api의 크롤링 데이터 적재 양쪽에서 사용)
# 양식: mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://admin:your_secure_password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
